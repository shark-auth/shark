{
  "info": {
    "name": "SharkAuth",
    "description": "SharkAuth API — single-binary authentication server",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "admin_key", "value": "admin-dev-key-123" },
    { "key": "user_email", "value": "test@example.com" },
    { "key": "user_password", "value": "password123" },
    { "key": "user_id", "value": "" },
    { "key": "role_id", "value": "" },
    { "key": "perm_id", "value": "" },
    { "key": "api_key_id", "value": "" },
    { "key": "api_key_full", "value": "" },
    { "key": "mfa_secret", "value": "" },
    { "key": "sso_connection_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Healthz",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/healthz", "host": ["{{base_url}}"], "path": ["healthz"] }
          }
        }
      ]
    },
    {
      "name": "Auth — Core",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set('user_id', body.id);",
                  "    pm.test('User created', () => pm.expect(body.email).to.eql(pm.collectionVariables.get('user_email')));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\",\n  \"name\": \"Test User\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/signup", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "signup"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/auth/me", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Auth — MFA",
      "item": [
        {
          "name": "Enroll MFA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set('mfa_secret', body.secret);",
                  "    console.log('QR URI:', body.qr_uri);",
                  "    console.log('Secret:', body.secret);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa/enroll", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "mfa", "enroll"] }
          }
        },
        {
          "name": "Verify MFA (confirm setup)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa/verify", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "mfa", "verify"] },
            "description": "Replace 000000 with real TOTP code from authenticator app"
          }
        },
        {
          "name": "MFA Challenge (during login)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"000000\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa/challenge", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "mfa", "challenge"] },
            "description": "Replace 000000 with real TOTP code"
          }
        },
        {
          "name": "MFA Recovery Code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"your-recovery-code\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa/recovery", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "mfa", "recovery"] }
          }
        },
        {
          "name": "Regenerate Recovery Codes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa/recovery-codes", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "mfa", "recovery-codes"] }
          }
        },
        {
          "name": "Disable MFA",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"000000\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/mfa", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "mfa"] },
            "description": "Requires valid current TOTP code"
          }
        }
      ]
    },
    {
      "name": "Auth — Magic Links",
      "item": [
        {
          "name": "Send Magic Link",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"magicuser@example.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/magic-link/send", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "magic-link", "send"] },
            "description": "Always returns 200. Check server logs for token (SMTP must be configured for actual email)."
          }
        },
        {
          "name": "Verify Magic Link",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/auth/magic-link/verify?token=PASTE_TOKEN_HERE",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "magic-link", "verify"],
              "query": [{ "key": "token", "value": "PASTE_TOKEN_HERE" }]
            },
            "description": "Paste the token from the magic link email. Redirects and sets session cookie."
          }
        }
      ]
    },
    {
      "name": "Auth — Passkeys",
      "item": [
        {
          "name": "Register Begin",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/auth/passkey/register/begin", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "passkey", "register", "begin"] },
            "description": "Requires active session. Returns PublicKeyCredentialCreationOptions."
          }
        },
        {
          "name": "Login Begin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/passkey/login/begin", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "passkey", "login", "begin"] },
            "description": "Send empty body {} for discoverable credential flow (no email needed)."
          }
        },
        {
          "name": "List Credentials",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/auth/passkey/credentials", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "passkey", "credentials"] },
            "description": "Requires active session."
          }
        }
      ]
    },
    {
      "name": "Auth — OAuth",
      "item": [
        {
          "name": "OAuth Google",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/auth/oauth/google", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "oauth", "google"] },
            "description": "Redirects to Google consent. Requires google.client_id configured."
          }
        },
        {
          "name": "OAuth GitHub",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/auth/oauth/github", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "oauth", "github"] }
          }
        },
        {
          "name": "OAuth Discord",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/auth/oauth/discord", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "oauth", "discord"] }
          }
        }
      ]
    },
    {
      "name": "Auth — Check Permission",
      "item": [
        {
          "name": "Check Permission",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"action\": \"write\",\n  \"resource\": \"posts\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/check", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "check"] }
          }
        }
      ]
    },
    {
      "name": "RBAC — Roles",
      "item": [
        {
          "name": "Create Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('role_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"editor\",\n  \"description\": \"Can edit content\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/roles", "host": ["{{base_url}}"], "path": ["api", "v1", "roles"] }
          }
        },
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/roles", "host": ["{{base_url}}"], "path": ["api", "v1", "roles"] }
          }
        },
        {
          "name": "Get Role",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/roles/{{role_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "roles", "{{role_id}}"] }
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"editor\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/roles/{{role_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "roles", "{{role_id}}"] }
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/roles/{{role_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "roles", "{{role_id}}"] }
          }
        },
        {
          "name": "Attach Permission to Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission_id\": \"{{perm_id}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/roles/{{role_id}}/permissions", "host": ["{{base_url}}"], "path": ["api", "v1", "roles", "{{role_id}}", "permissions"] }
          }
        },
        {
          "name": "Detach Permission from Role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/roles/{{role_id}}/permissions/{{perm_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "roles", "{{role_id}}", "permissions", "{{perm_id}}"] }
          }
        }
      ]
    },
    {
      "name": "RBAC — Permissions",
      "item": [
        {
          "name": "Create Permission",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('perm_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"write\",\n  \"resource\": \"posts\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/permissions", "host": ["{{base_url}}"], "path": ["api", "v1", "permissions"] }
          }
        },
        {
          "name": "List Permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/permissions", "host": ["{{base_url}}"], "path": ["api", "v1", "permissions"] }
          }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "Assign Role to User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role_id\": \"{{role_id}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/users/{{user_id}}/roles", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "{{user_id}}", "roles"] }
          }
        },
        {
          "name": "List User Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users/{{user_id}}/roles", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "{{user_id}}", "roles"] }
          }
        },
        {
          "name": "List User Effective Permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users/{{user_id}}/permissions", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "{{user_id}}", "permissions"] }
          }
        },
        {
          "name": "Remove Role from User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users/{{user_id}}/roles/{{role_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "{{user_id}}", "roles", "{{role_id}}"] }
          }
        },
        {
          "name": "User Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users/{{user_id}}/audit-logs", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "{{user_id}}", "audit-logs"] }
          }
        }
      ]
    },
    {
      "name": "M2M API Keys",
      "item": [
        {
          "name": "Create API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set('api_key_id', body.id);",
                  "    pm.collectionVariables.set('api_key_full', body.key);",
                  "    console.log('SAVE THIS KEY:', body.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"backend-service\",\n  \"scopes\": [\"users:read\", \"roles:read\"],\n  \"rate_limit\": 100\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/api-keys", "host": ["{{base_url}}"], "path": ["api", "v1", "api-keys"] }
          }
        },
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/api-keys", "host": ["{{base_url}}"], "path": ["api", "v1", "api-keys"] }
          }
        },
        {
          "name": "Get API Key",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/api-keys/{{api_key_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "api-keys", "{{api_key_id}}"] }
          }
        },
        {
          "name": "Update API Key",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"updated-service\",\n  \"scopes\": [\"users:read\", \"users:write\"]\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/api-keys/{{api_key_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "api-keys", "{{api_key_id}}"] }
          }
        },
        {
          "name": "Revoke API Key",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/api-keys/{{api_key_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "api-keys", "{{api_key_id}}"] }
          }
        },
        {
          "name": "Rotate API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set('api_key_id', body.id);",
                  "    pm.collectionVariables.set('api_key_full', body.key);",
                  "    console.log('NEW KEY:', body.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/api-keys/{{api_key_id}}/rotate", "host": ["{{base_url}}"], "path": ["api", "v1", "api-keys", "{{api_key_id}}", "rotate"] }
          }
        },
        {
          "name": "Use API Key (Bearer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key_full}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users", "host": ["{{base_url}}"], "path": ["api", "v1", "users"] },
            "description": "Uses the M2M API key instead of admin key. Scope must include users:read."
          }
        }
      ]
    },
    {
      "name": "SSO",
      "item": [
        {
          "name": "Create SSO Connection (OIDC)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('sso_connection_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"oidc\",\n  \"name\": \"Okta Dev\",\n  \"domain\": \"company.com\",\n  \"oidc_issuer\": \"https://dev-123456.okta.com\",\n  \"oidc_client_id\": \"your-client-id\",\n  \"oidc_client_secret\": \"your-secret\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/sso/connections", "host": ["{{base_url}}"], "path": ["api", "v1", "sso", "connections"] }
          }
        },
        {
          "name": "List SSO Connections",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Key", "value": "{{admin_key}}" }],
            "url": { "raw": "{{base_url}}/api/v1/sso/connections", "host": ["{{base_url}}"], "path": ["api", "v1", "sso", "connections"] }
          }
        },
        {
          "name": "SSO Auto-Route by Email",
          "request": {
            "method": "GET",
            "url": {
